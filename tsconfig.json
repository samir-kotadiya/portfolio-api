{
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "jest.config.ts", 
    "**/*.test.ts"
  ],
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",
    
    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "types": [
      "jest",
      "node"
    ],
    //"esModuleInterop": true,
    //"allowJs": true,
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node
    // Other Outputs
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,
    // Recommended Options
    "strict": true,
    //"jsx": "react-jsx",
    "verbatimModuleSyntax": true,  // remove type define with import
    "isolatedModules": true, // ensures every TypeScript file is treated as a standalone module (isolated)
    // "noUncheckedSideEffectImports": true, // used to ensure that side-effect imports (like importing a CSS file or a polyfill) actually point to a file that exists
    "moduleDetection": "force", // forces TypeScript to treat every non-declaration (.ts, .tsx) file as an ECMAScript module, regardless of whether it contains top-level import or export statements
    "skipLibCheck": true, // instructs the compiler to skip type checking of all declaration files (.d.ts) // Ignore Third-Party Errors, Performance Boost
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}